               },
               {
                  "name": "verificationDocs",
                  "type": "general",
                  "entity": "Application.studentsInfo.enrollmentVerificationDocumentDetails"
               }
            ],
            "ccId": 1,
            "rules": [
               {
                  "ruleId": "Rule_A0",
                  "actions": [{
                     "expression": "Application.applicationDetails.applicationProcessingStatus",
                     "value": "submitted"
                  }]
               },
               {
                  "conditions": [{
                     "expression": "Application.parentGuardianInfo.profile.emailAddress",
                     "value": "null"
                  }],
                  "ruleId": "Rule_1",
                  "actions": [{
                     "expression": "Application.applicationDetails.applicationProcessingStatus",
                     "value": "on_hold"
                  }]
               },
               {
                  "conditions": [{
                     "expression": "Application.parentGuardianInfo.profile.firstName",
                     "value": "null"
                  }],
                  "ruleId": "Rule_2",
                  "actions": [{
                     "expression": "Application.applicationDetails.applicationProcessingStatus",
                     "value": "on_hold"
                  }]
               },
               {
                  "conditions": [{
                     "expression": "Application.parentGuardianInfo.profile.lastName",
                     "value": "null"
                  }],
                  "ruleId": "Rule_3",
                  "actions": [{
                     "expression": "Application.applicationDetails.applicationProcessingStatus",
                     "value": "on_hold"
                  }]
               },
               {
                  "conditions": [{
                     "expression": "Application.parentGuardianInfo.profile.phoneNumber",
                     "value": "null"
                  }],
                  "ruleId": "Rule_4",
                  "actions": [{
                     "expression": "Application.applicationDetails.applicationProcessingStatus",
                     "value": "on_hold"
                  }]
               },
               {
                  "rulestatements": [{
                     "severity": "Warning",
                     "alias": "Application",
                     "text": "Enrollment verification document details missing for one or more students."
                  }],
                  "conditions": [{
                     "expression": "verificationDocs->isEmpty",
                     "value": "T"
                  }],
                  "ruleId": "Rule_5",
                  "actions": [{
                     "expression": "Application.applicationDetails.applicationProcessingStatus",
                     "value": "on_hold"
                  }]
               },
               {
                  "rulestatements": [{
                     "severity": "Warning",
                     "alias": "studentApps",
                     "text": "Invalid enrollment verification document type submitted for one or more students."
                  }],
                  "conditions": [{
                     "expression": "verificationDocs.documentTypeSubmitted",
                     "value": "not {DocumentTypeSubmittedEnumeration#public_school_progress_report_copy, DocumentTypeSubmittedEnumeration#public_school_report_card_copy, DocumentTypeSubmittedEnumeration#online_grade_portal_printout_or_screenshot, DocumentTypeSubmittedEnumeration#school_letter_on_school_letterhead}"
                  }],
                  "ruleId": "Rule_6",
                  "actions": [{
                     "expression": "Application.applicationDetails.applicationProcessingStatus",
                     "value": "on_hold"
                  }]
               },
               {
                  "conditions": [{
                     "expression": "verificationDocs.requiredDocumentContent.includesCurrentEnrollmentStatus",
                     "value": "F"
                  }],
                  "ruleId": "Rule_7",
                  "actions": [{
                     "expression": "Application.applicationDetails.applicationProcessingStatus",
                     "value": "on_hold"
                  }]
               },
               {
                  "conditions": [{
                     "expression": "verificationDocs.requiredDocumentContent.includesSchoolAddress",
                     "value": "F"
                  }],
                  "ruleId": "Rule_8",
                  "actions": [{
                     "expression": "Application.applicationDetails.applicationProcessingStatus",
                     "value": "on_hold"
                  }]
               },
               {
                  "conditions": [{
                     "expression": "verificationDocs.requiredDocumentContent.includesSchoolName",
                     "value": "F"
                  }],
                  "ruleId": "Rule_9",
                  "actions": [{
                     "expression": "Application.applicationDetails.applicationProcessingStatus",
                     "value": "on_hold"
                  }]
               },
               {
                  "conditions": [{
                     "expression": "verificationDocs.requiredDocumentContent.includesStudentName",
                     "value": "F"
                  }],
                  "ruleId": "Rule_10",
                  "actions": [{
                     "expression": "Application.applicationDetails.applicationProcessingStatus",
                     "value": "on_hold"
                  }]
               },
               {
                  "conditions": [{
                     "expression": "verificationDocs.requiredDocumentContent.includesSchoolYear",
                     "value": "F"
                  }],
                  "ruleId": "Rule_11",
                  "actions": [{
                     "expression": "Application.applicationDetails.applicationProcessingStatus",
                     "value": "on_hold"
                  }]
               }
            ],
            "ccName": "Application Data Validations"
         },
         {
            "aliases": [
               {
                  "name": "appDetail",
                  "type": "general",
                  "entity": "Application.applicationDetails"
               },
               {
                  "name": "studentInfo",
                  "type": "general",
                  "entity": "Application.studentsInfo"
               }
            ],
            "ccId": 2,
            "rules": [
               {
                  "ruleId": "Rule_A0",
                  "actions": [{
                     "expression": "studentInfo.isStudentEligibleThisApplication",
                     "value": "T"
                  }]
               },
               {
                  "ruleId": "Rule_B0",
                  "actions": [{
                     "expression": "appDetail.householdStipendDetails.isHouseholdDeterminedEligible",
                     "value": "F"
                  }]
               },
               {
                  "ruleId": "Rule_C0",
                  "actions": [{
                     "expression": "appDetail.applicationProcessingStatus",
                     "value": "awarded"
                  }]
               },
               {
                  "rulestatements": [{
                     "severity": "Violation",
                     "alias": "studentInfo",
                     "text": "Student not in eligible grade K-8"
                  }],
                  "conditions": [{
                     "expression": "studentInfo.gradeLevel",
                     "value": "not {GradeLevelEnumeration#K, GradeLevelEnumeration#1, GradeLevelEnumeration#2, GradeLevelEnumeration#3, GradeLevelEnumeration#4, GradeLevelEnumeration#5, GradeLevelEnumeration#6, GradeLevelEnumeration#7, GradeLevelEnumeration#8}"
                  }],
                  "ruleId": "Rule_1",
                  "actions": [{
                     "expression": "studentInfo.isStudentEligibleThisApplication",
                     "value": "F"
                  }]
               },
               {
                  "rulestatements": [{
                     "severity": "Violation",
                     "alias": "studentInfo",
                     "text": "Student not enrolled in a nonvirtual public school"
                  }],
                  "conditions": [{
                     "expression": "studentInfo.qualifyingSchoolEnrollmentDetails.isNonVirtualPublicSchool",
                     "value": "F"
                  }],
                  "ruleId": "Rule_2",
                  "actions": [{
                     "expression": "studentInfo.isStudentEligibleThisApplication",
                     "value": "F"
                  }]
               },
               {
                  "rulestatements": [{
                     "severity": "Violation",
                     "alias": "studentInfo",
                     "text": "Student's chosen school is not different from their assigned school."
                  }],
                  "conditions": [{
                     "expression": "studentInfo.qualifyingSchoolEnrollmentDetails.isDifferentFromAssignedSchool",
                     "value": "F"
                  }],
                  "ruleId": "Rule_3",
                  "actions": [{
                     "expression": "studentInfo.isStudentEligibleThisApplication",
                     "value": "F"
                  }]
               },
               {
                  "rulestatements": [{
                     "severity": "Violation",
                     "alias": "studentInfo",
                     "text": "Student's school type is not a qualifying type."
                  }],
                  "conditions": [{
                     "expression": "studentInfo.qualifyingSchoolEnrollmentDetails.qualifyingSchoolType",
                     "value": "not {QualifyingSchoolTypeEnumeration#magnet_school, QualifyingSchoolTypeEnumeration#district_school_of_choice, QualifyingSchoolTypeEnumeration#charter_school, QualifyingSchoolTypeEnumeration#developmental_research_school, QualifyingSchoolTypeEnumeration#district_open_enrollment_policy_school}"
                  }],
                  "ruleId": "Rule_4",
                  "actions": [{
                     "expression": "studentInfo.isStudentEligibleThisApplication",
                     "value": "F"
                  }]
               },
               {
                  "rulestatements": [{
                     "severity": "Violation",
                     "alias": "studentInfo",
                     "text": "Student is participating in another conflicting Florida K-12 scholarship program."
                  }],
                  "conditions": [
                     {
                        "expression": "studentInfo.participatingInOtherConflictingK12Scholarship",
                        "value": "T"
                     },
                     {
                        "expression": "appDetail.applicationProcessingStatus",
                        "value": "not null"
                     }
                  ],
                  "ruleId": "Rule_5",
                  "actions": [{
                     "expression": "studentInfo.isStudentEligibleThisApplication",
                     "value": "F"
                  }]
               },
               {
                  "conditions": [{
                     "expression": "studentInfo.isStudentEligibleThisApplication",
                     "value": "T"
                  }],
                  "ruleId": "Rule_6",
                  "actions": [{
                     "expression": "appDetail.householdStipendDetails.isHouseholdDeterminedEligible",
                     "value": "T"
                  }]
               },
               {
                  "rulestatements": [{
                     "severity": "Violation",
                     "alias": "appDetail",
                     "text": "No students in the application meet eligibility criteria."
                  }],
                  "conditions": [
                     {
                        "expression": "appDetail.applicationProcessingStatus",
                        "value": "null"
                     },
                     {
                        "expression": "appDetail.householdStipendDetails.isHouseholdDeterminedEligible",
                        "value": "F"
                     }
                  ],
                  "ruleId": "Rule_7",
                  "actions": [{
                     "expression": "appDetail.applicationProcessingStatus",
                     "value": "ineligible"
                  }]
               },
               {
                  "rulestatements": [{
                     "severity": "Violation",
                     "alias": "appDetail",
                     "text": "Application ineligible due to one or more students participating in a conflicting K-12 scholarship."
                  }],
                  "conditions": [
                     {
                        "expression": "studentInfo.participatingInOtherConflictingK12Scholarship",
                        "value": "T"
                     },
                     {
                        "expression": "appDetail.applicationProcessingStatus",
                        "value": "null"
                     }
                  ],
                  "ruleId": "Rule_8",
                  "actions": [{
                     "expression": "appDetail.applicationProcessingStatus",
                     "value": "ineligible"
                  }]
               }
            ],
            "filters": [{"expression": "appDetail.applicationProcessingStatus <> 'on_hold'"}],
            "ccName": "Eligibility"
         },
         {
            "aliases": [{
               "name": "pastApps",
               "type": "general",
               "entity": "Application.parentGuardianInfo.historicalHouseholdData"
            }],
            "ccId": 3,
            "rules": [
               {
                  "rulestatements": [{
                     "severity": "Violation",
                     "alias": "Application",
                     "text": "Household has already been awarded a stipend for this school year based on historical data."
                  }],
                  "conditions": [{
                     "expression": "pastApps->exists(schoolYear=Application.applicationDetails.applicableSchoolYear and wasStipendAwardedThisHousehold=T)",
                     "value": "T"
                  }],
                  "ruleId": "Rule_1",
                  "actions": [{
                     "expression": "Application.applicationDetails.applicationProcessingStatus",
                     "value": "ineligible"
                  }]
               },
               {
                  "rulestatements": [{
                     "severity": "Warning",
                     "alias": "Application",
                     "text": "Program at Capacity"
                  }],
                  "conditions": [
                     {
                        "expression": "Application.applicationDetails.applicationProcessingStatus",
                        "value": "null"
                     },
                     {
                        "expression": "Application.programInformation.isProgramCurrentlyAtCapacity",
                        "value": "T"
                     }
                  ],
                  "ruleId": "Rule_2",
                  "actions": [{
                     "expression": "Application.applicationDetails.applicationProcessingStatus",
                     "value": "at_capacity"
                  }]
               },
               {
                  "conditions": [
                     {
                        "expression": "Application.applicationDetails.applicationProcessingStatus",
                        "value": "null"
                     },
                     {
                        "expression": "Application.applicationDetails.applicableSchoolYear",
                        "value": "'2024-25'"
                     }
                  ],
                  "ruleId": "Rule_3",
                  "actions": [{
                     "expression": "Application.applicationDetails.fundingPriorityCategory",
                     "value": "FundingPriorityCategoryEnumeration#priority_2023_24_FES_FTC_transportation_recipient"
                  }]
               },
               {
                  "conditions": [
                     {
                        "expression": "Application.applicationDetails.applicationProcessingStatus",
                        "value": "null"
                     },
                     {
                        "expression": "Application.applicationDetails.applicableSchoolYear.indexOf('2025')",
                        "value": "1"
                     }
                  ],
                  "ruleId": "Rule_4",
                  "actions": [{
                     "expression": "Application.applicationDetails.fundingPriorityCategory",
                     "value": "FundingPriorityCategoryEnumeration#priority_renewing_household_2025_26_onwards"
                  }]
               },
               {
                  "conditions": [
                     {
                        "expression": "Application.applicationDetails.applicationProcessingStatus",
                        "value": "null"
                     },
                     {
                        "expression": "Application.applicationDetails.applicableSchoolYear.indexOf('2026')",
                        "value": "1"
                     }
                  ],
                  "ruleId": "Rule_5",
                  "actions": [{
                     "expression": "Application.applicationDetails.fundingPriorityCategory",
                     "value": "FundingPriorityCategoryEnumeration#priority_renewing_household_2025_26_onwards"
                  }]
               },
               {
                  "conditions": [
                     {
                        "expression": "Application.applicationDetails.applicationProcessingStatus",
                        "value": "null"
                     },
                     {
                        "expression": "Application.applicationDetails.fundingPriorityCategory",
                        "value": "null"
                     }
                  ],
                  "ruleId": "Rule_6",
                  "actions": [{
                     "expression": "Application.applicationDetails.fundingPriorityCategory",
                     "value": "FundingPriorityCategoryEnumeration#standard_first_come_first_served"
                  }]
               },
               {
                  "rulestatements": [{
                     "severity": "Warning",
                     "alias": "Application",
                     "text": "Insufficient funds to award stipend at this time."
                  }],
                  "conditions": [
                     {
                        "expression": "Application.applicationDetails.applicationProcessingStatus",
                        "value": "null"
                     },
                     {
                        "expression": "Application.programInformation.currentAvailableFunds",
                        "value": ">=Application.applicationDetails.householdStipendDetails.stipendAmountPotentiallyAwarded"
                     }
                  ],
                  "ruleId": "Rule_7",
                  "actions": [
                     {
                        "expression": "Application.applicationDetails.applicationProcessingStatus",
                        "value": "awarded"
                     },
                     {
                        "expression": "Application.applicationDetails.householdStipendDetails.stipendAmountAwardedThisApplication",
                        "value": "Application.applicationDetails.householdStipendDetails.stipendAmountPotentiallyAwarded"
                     }
                  ]
               },
               {
                  "conditions": [
                     {
                        "expression": "Application.applicationDetails.applicationProcessingStatus",
                        "value": "null"
                     },
                     {
                        "expression": "Application.programInformation.currentAvailableFunds",
                        "value": "<Application.applicationDetails.householdStipendDetails.stipendAmountPotentiallyAwarded"
                     }
                  ],
                  "ruleId": "Rule_8",
                  "actions": [{
                     "expression": "Application.applicationDetails.applicationProcessingStatus",
                     "value": "at_capacity"
                  }]
               },
               {
                  "conditions": [
                     {
                        "expression": "Application.applicationDetails.applicationProcessingStatus",
                        "value": "awarded"
                     },
                     {
                        "expression": "Application.applicationDetails.stipendDeclineInformation.userRequestsDecline",
                        "value": "T"
                     },
                     {
                        "expression": "Application.applicationDetails.isStipendPaidForThisApplication",
                        "value": "F"
                     }
                  ],
                  "ruleId": "Rule_9",
                  "actions": [
                     {
                        "expression": "Application.applicationDetails.applicationProcessingStatus",
                        "value": "declined_by_user"
                     },
                     {
                        "expression": "Application.applicationDetails.householdStipendDetails.stipendAmountAwardedThisApplication",
                        "value": "0"
                     },
                     {
                        "expression": "Application.applicationDetails.stipendDeclineInformation.hasBeenEffectivelyDeclined",
                        "value": "T"
                     }
                  ]
               },
               {
                  "conditions": [
                     {
                        "expression": "Application.applicationDetails.stipendDeclineInformation.userRequestsDecline",
                        "value": "T"
                     },
                     {
                        "expression": "Application.applicationDetails.isStipendPaidForThisApplication",
                        "value": "T"
                     }
                  ],
                  "ruleId": "Rule_10",
